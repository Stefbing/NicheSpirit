<view class="page screen">
  <view class="bg-grid"></view>
  <view class="bg-orb one"></view>
  <view class="bg-orb two"></view>

  <view class="content">
    <view class="card hero spark">
      <view class="eyebrow">AutoHome · Family Control</view>
      <view class="hero-title" style="margin-top: 18rpx;">{{dashboard.scene.title || '家庭控制中心'}}</view>
      <view class="hero-subtitle">{{dashboard.scene.subtitle || '统一管理设备、状态、缓存和操作闭环。'}}</view>
      <view class="pill-row" style="margin-top: 22rpx;">
        <view class="chip">后端 {{connection.apiBase}}</view>
        <view class="chip">{{statusText}}</view>
      </view>
      <view class="chip-row" style="margin-top: 14rpx;">
        <view class="pill">实时同步</view>
        <view class="pill">局域网优先</view>
        <view class="pill">无感刷新</view>
        <view class="pill">{{dashboard.has_devices ? '已绑定 ' + (dashboard.devices ? dashboard.devices.length : 0) + ' 台设备' : '等待添加设备'}}</view>
      </view>
      <view class="btn-row" style="margin-top: 22rpx;">
        <button class="action-btn" bindtap="runQuickAction" data-action="feed">快速喂食</button>
        <button class="ghost-btn" bindtap="runQuickAction" data-action="clean">猫厕清理</button>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">核心指标</view>
        <view class="section-meta">自动刷新缓存</view>
      </view>
      <view class="grid-2">
        <view class="metric" wx:for="{{dashboard.overview}}" wx:key="label" wx:for-index="index" style="animation-delay: {{index * 0.06}}s;">
          <view class="metric-value">{{item.value}}</view>
          <view class="metric-label">{{item.label}}</view>
          <view class="metric-trend">{{item.trend}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">设备面板</view>
        <view class="section-meta">PetKit / CloudPets / Xiaomi</view>
      </view>
      <view class="device-list">
        <view class="device-card" wx:for="{{dashboard.petkit_devices}}" wx:key="id" wx:for-index="index" style="animation-delay: {{index * 0.08}}s;">
          <view class="device-top">
            <view>
              <view class="device-name">{{item.name}}</view>
              <view class="device-meta">{{item.model}} · {{item.last_cleaned_at}}</view>
            </view>
            <view class="status-dot {{item.status === 'online' ? '' : 'warn'}}"></view>
          </view>
          <view class="sub">今日访问 {{item.stats.today_visits}} 次 · 平均时长 {{item.stats.avg_duration}}</view>
          <view class="meter"><view class="meter-bar" style="width: {{item.sand_level}}%;"></view></view>
          <view class="device-foot" style="margin-top: 14rpx;">
            <view class="tag-row">
              <view class="tag">猫砂 {{item.sand_level}}%</view>
              <view class="tag">异味 {{item.odor_level}}</view>
            </view>
            <button class="ghost-btn" bindtap="goLitterbox">操作</button>
          </view>
        </view>

        <view class="device-card">
          <view class="device-top">
            <view>
              <view class="device-name">{{dashboard.cloudpets.name || '喂食器'}}</view>
              <view class="device-meta">电量 {{dashboard.cloudpets.battery || 0}}% · 今日 {{dashboard.cloudpets.servings_today || 0}} 次</view>
            </view>
            <view class="status-dot"></view>
          </view>
          <view class="sub">计划 {{dashboard.cloudpets.plans ? dashboard.cloudpets.plans.length : 0}} 个 · 当前食量 {{dashboard.cloudpets.food_level || 0}}%</view>
          <view class="progress"><view class="progress-bar" style="width: {{dashboard.cloudpets.food_level || 0}}%;"></view></view>
          <view class="btn-row" style="margin-top: 14rpx;">
            <button class="action-btn" bindtap="goFeeder">进入喂食器</button>
            <button class="ghost-btn" bindtap="runQuickAction" data-action="refresh">刷新</button>
          </view>
        </view>

        <view class="device-card">
          <view class="device-top">
            <view>
              <view class="device-name">小米云同步</view>
              <view class="device-meta">{{dashboard.xiaomi.message || '同步状态'}}</view>
            </view>
            <view class="status-dot {{dashboard.xiaomi.connected ? '' : 'warn'}}"></view>
          </view>
          <view class="sub">最近同步 {{dashboard.xiaomi.last_sync_at || '暂无'}} · 体重记录自动推送</view>
          <view class="btn-row" style="margin-top: 14rpx;">
            <button class="ghost-btn" bindtap="goScale">查看体脂秤</button>
            <button class="plain-btn" bindtap="goSettings">连接设置</button>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">热点聚合</view>
        <view class="section-meta">微博 / 抖音 / X / GitHub</view>
      </view>
      <view class="card hot-shell">
        <view class="hot-head">
          <view>
            <view class="title">趋势雷达</view>
            <view class="sub">后端接入后，会按来源聚合、去重排序，并写入首页缓存。</view>
          </view>
          <view class="live-badge">LIVE</view>
        </view>
        <view class="chip-row" style="margin-top: 16rpx;">
          <view class="pill">微博热榜</view>
          <view class="pill">抖音趋势</view>
          <view class="pill">X 热点</view>
          <view class="pill">GitHub Trending</view>
        </view>

        <view wx:if="{{dashboard.hotspots && dashboard.hotspots.length}}">
          <view class="trend-list">
            <view class="trend-item" wx:for="{{dashboard.hotspots}}" wx:key="id" wx:for-index="index">
              <view class="trend-rank">#{{index + 1}}</view>
              <view class="trend-body">
                <view class="trend-title">{{item.title}}</view>
                <view class="trend-meta">{{item.source}} · {{item.hotness}}</view>
              </view>
              <view class="trend-badge">{{item.tag}}</view>
            </view>
          </view>
        </view>

        <view wx:else class="section-empty" style="margin-top: 16rpx;">
          热点聚合服务暂未接入，当前保留展示位。接上后端后，这里会自动填充微博、抖音、X 和 GitHub 热榜。
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-head">
        <view class="section-title">快捷入口</view>
        <view class="section-meta">两步直达</view>
      </view>
      <view class="btn-row">
        <button class="ghost-btn" bindtap="goFeeder">喂食器</button>
        <button class="ghost-btn" bindtap="goLitterbox">猫厕所</button>
        <button class="ghost-btn" bindtap="goScale">体脂秤</button>
        <button class="plain-btn" bindtap="goSettings">连接设置</button>
      </view>
    </view>
  </view>
</view>
