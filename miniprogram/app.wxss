page {
  background:
    radial-gradient(circle at top left, rgba(31, 111, 235, 0.14), transparent 28%),
    radial-gradient(circle at top right, rgba(0, 179, 255, 0.1), transparent 24%),
    linear-gradient(180deg, #f7fbff 0%, #eef4fb 100%);
  color: #0f172a;
  font-family: PingFang SC, Microsoft YaHei, sans-serif;
}

button::after {
  border: none;
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 24rpx;
}

.screen {
  position: relative;
}

.bg-orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(18px);
  opacity: 0.65;
  animation: float 10s ease-in-out infinite;
}

.bg-orb.one {
  top: -120rpx;
  left: -120rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle, rgba(31, 111, 235, 0.32) 0%, rgba(31, 111, 235, 0) 72%);
}

.bg-orb.two {
  top: 260rpx;
  right: -140rpx;
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(0, 179, 255, 0.24) 0%, rgba(0, 179, 255, 0) 72%);
  animation-delay: -2s;
}

.bg-grid {
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0.25;
  background-image:
    linear-gradient(rgba(148, 163, 184, 0.12) 1px, transparent 1px),
    linear-gradient(90deg, rgba(148, 163, 184, 0.12) 1px, transparent 1px);
  background-size: 48rpx 48rpx;
  mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.55) 0%, transparent 100%);
}

.content {
  position: relative;
  z-index: 1;
}

.card {
  position: relative;
  background: rgba(255, 255, 255, 0.88);
  border: 1px solid rgba(15, 23, 42, 0.08);
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.08);
  margin-bottom: 24rpx;
  backdrop-filter: blur(16px);
}

.card::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), transparent 42%);
  pointer-events: none;
}

.hero {
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(31, 111, 235, 0.9)),
    linear-gradient(180deg, #0f172a 0%, #111827 100%);
  color: #f8fafc;
}

.hero::before {
  content: "";
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.18) 0%, rgba(255, 255, 255, 0) 68%);
  animation: pulse 6s ease-in-out infinite;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: 1rpx;
}

.hero-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(248, 250, 252, 0.82);
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  font-size: 22rpx;
  letter-spacing: 1rpx;
  color: rgba(248, 250, 252, 0.88);
}

.chip-row,
.pill-row,
.action-row,
.shortcut-row,
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip,
.pill,
.tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.chip {
  background: rgba(255, 255, 255, 0.12);
  color: rgba(248, 250, 252, 0.94);
}

.pill,
.tag {
  background: rgba(31, 111, 235, 0.08);
  color: #1f6feb;
}

.pill {
  border: 1px solid rgba(31, 111, 235, 0.08);
}

.section {
  margin-bottom: 24rpx;
}

.section-head {
  display: flex;
  align-items: end;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-meta {
  font-size: 22rpx;
  color: #64748b;
}

.sub {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.6;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
}

.grid-2 {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.metric {
  width: calc(50% - 8rpx);
  padding: 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7faff 100%);
  border: 1px solid rgba(31, 111, 235, 0.08);
  animation: cardIn 0.55s ease both;
}

.metric-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.metric-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.metric-trend {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #1f6feb;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mini-card,
.device-card,
.feed-card,
.hot-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(15, 23, 42, 0.08);
}

.hot-shell {
  padding: 26rpx;
}

.hot-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.live-badge {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(34, 197, 94, 0.12);
  color: #16a34a;
  font-size: 20rpx;
  letter-spacing: 1rpx;
}

.trend-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.trend-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  border: 1px solid rgba(31, 111, 235, 0.08);
  animation: cardIn 0.45s ease both;
}

.trend-rank {
  min-width: 58rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #1f6feb;
}

.trend-body {
  flex: 1;
  min-width: 0;
}

.trend-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.trend-meta {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #64748b;
}

.trend-badge {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(31, 111, 235, 0.08);
  color: #1f6feb;
  font-size: 20rpx;
  white-space: nowrap;
}

.device-card {
  animation: cardIn 0.55s ease both;
}

.device-top,
.device-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.device-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.device-meta,
.muted {
  font-size: 22rpx;
  color: #64748b;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #22c55e;
  box-shadow: 0 0 0 10rpx rgba(34, 197, 94, 0.12);
}

.status-dot.warn {
  background: #f59e0b;
  box-shadow: 0 0 0 10rpx rgba(245, 158, 11, 0.12);
}

.status-dot.bad {
  background: #ef4444;
  box-shadow: 0 0 0 10rpx rgba(239, 68, 68, 0.12);
}

.meter,
.progress {
  height: 14rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  overflow: hidden;
}

.meter-bar,
.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1f6feb, #00b3ff);
}

.button,
.action-btn,
.ghost-btn,
.plain-btn,
.danger-btn,
.primary-btn,
.secondary-btn {
  min-width: 0;
  border-radius: 18rpx;
  font-size: 26rpx;
  line-height: 1.1;
}

.action-btn,
.primary-btn {
  background: linear-gradient(135deg, #1f6feb, #0ea5e9);
  color: #fff;
}

.ghost-btn {
  background: rgba(31, 111, 235, 0.08);
  color: #1f6feb;
}

.plain-btn,
.secondary-btn {
  background: #e2e8f0;
  color: #0f172a;
}

.danger-btn {
  background: rgba(239, 68, 68, 0.12);
  color: #dc2626;
}

.btn-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.section-empty {
  padding: 26rpx;
  border-radius: 24rpx;
  border: 1px dashed rgba(31, 111, 235, 0.24);
  background: rgba(31, 111, 235, 0.04);
  color: #334155;
  line-height: 1.6;
}

.input {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1px solid rgba(15, 23, 42, 0.08);
}

.hint {
  margin-top: 14rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.6;
}

.spark {
  animation: pulse 4s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
  50% { transform: translate3d(0, 16rpx, 0) scale(1.06); }
}

@keyframes pulse {
  0%, 100% { opacity: 0.65; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.03); }
}

@keyframes cardIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}
